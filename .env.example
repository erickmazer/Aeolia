# Aeolia — variáveis de ambiente
# Copie para .env.local (ignorado pelo git) e preencha. Configure as mesmas na Vercel.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# IA (gerador de ficha + personalização). Fala no formato da API Anthropic,
# mas por enquanto aponta para o endpoint compatível da z.ai/GLM (mais barato).
ANTHROPIC_API_KEY=            # sua chave da z.ai (https://z.ai/manage-apikey/apikey-list)
# Endpoint compatível (default: z.ai). Para usar a Anthropic: https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# Modelos (default: glm-4.5-air, barato). Veja os disponíveis no painel da z.ai.
# FICHE_MODEL=glm-4.5-air
# PERSONALIZATION_MODEL=glm-4.5-air

# --- Apenas para rodar scripts localmente (NUNCA na Vercel / NUNCA commitar) ---
# Service-role key: só para o seed. Ignora RLS — trate como senha máxima.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# SHOWCASE_USER_ID=00000000-0000-0000-0000-000000000000
